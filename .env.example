# 本地开发环境变量，不提交到仓库（已在 .gitignore 中忽略）
# 复制此文件为 .env 并填写实际值

# ─── Anthropic API ────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=YOUR_API_KEY_HERE
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── 路径 ─────────────────────────────────────────────────────────────────────
# CCSERVER_PROJECT_DIR=./                      # 项目工作空间。tui 默认当前目录；api 部署时必须显式设置
# CCSERVER_GLOBAL_CONFIG_DIR=~/.ccserver       # 全局配置目录（skills/agents/hooks/commands/sessions/logs）

# ─── System prompt ────────────────────────────────────────────────────────────
# CCSERVER_SYSTEM_FILE=/path/to/system.md      # 启动时注入的额外 system prompt 文件
# CCSERVER_APPEND_SYSTEM=false                 # true=追加到 workflow 末尾；false=替换 workflow

# ─── 模型与限制（可选，不填则使用默认值）─────────────────────────────────────
# CCSERVER_MODEL=claude-sonnet-4-6
# CCSERVER_THRESHOLD=50000
# CCSERVER_KEEP_RECENT=3
# CCSERVER_MAIN_ROUNDS=100
# CCSERVER_SUB_ROUNDS=30
# CCSERVER_MAX_DEPTH=5

# ─── 日志 ─────────────────────────────────────────────────────────────────────
# CCSERVER_LOG_DIR=~/.ccserver/logs
# CCSERVER_LOG_LEVEL=DEBUG

# ─── 存储后端 ─────────────────────────────────────────────────────────────────
# CCSERVER_STORAGE_BACKEND=sqlite                # file或 sqlite（默认）
# CCSERVER_DB_PATH=~/.ccserver/ccserver.db     # sqlite 模式下的数据库路径

# ─── Prompt Lib ───────────────────────────────────────────────────────────────
# CCSERVER_PROMPT_LIB=cc_reverse:v2.1.81

# ─── Debug recording ─────────────────────────────────────────────────────────
# CCSERVER_RECORD_DIR=./records
