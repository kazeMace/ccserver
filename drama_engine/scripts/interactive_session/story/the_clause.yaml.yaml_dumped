meta:
  id: the_clause
  name: the_clause
  display_name: The Clause
  title: The Clause
  version: 1.0.0
  author: drama_engine
  description: 律师 Nora Hampton 与亿万富翁 Marco Diaz 之间的合约恋情故事。关键选择影响好感度，好感度决定结局走向。
  tags:
  - romance
  - drama
  - galgame
  locale: en-US
runtime:
  type: interactive_session
game_pack:
  plugin: builtin.stats
players:
  count: 1
  ids:
  - Player_1
  initial_attrs:
    alive: true
state:
  STORY:
    affection_marco: 0
    started: true
  GAME:
    round: 0
    ended: false
visibility:
  secret_attrs: []
guardrail:
  enabled: true
  checks:
  - in_character
  - on_topic
  on_violation: soft_warn
  evaluator:
    kind: llm
    provider: inside
flow:
