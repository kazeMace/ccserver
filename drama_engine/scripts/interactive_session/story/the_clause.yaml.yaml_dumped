scenes:
  s_01_first_meet:
    type: scene
    scope:
      id: story
      visibility: public
    participants:
      static:
      - Player_1
    schedule:
      mode: none
    participant_action:
      kind: none
      response:
        mode: none
    controller_action:
      enabled: true
      controller:
        type: human
      kind: choice
      choices:
      - id: get_in_car
        text: 上车
        to: node_05_02a
      - id: ignore_walk
        text: 不理他，继续往前走
        to: node_04_02b
      free_input:
        enabled: true
        mode: choose_mapping
        mapper:
          evaluator: plugin
          name: map_free_text_to_choice
    publication:
      messages:
      - audience:
          scope: story
        content:
          text: 律所会议室。你输掉了官司——Marco Diaz 在夜里收购了你的委托人。傍晚，他的车停在你公寓楼下等你。
      views:
      - id: node_01_video
        kind: video
        title: 第一幕·初遇
        audience: public
        projector: core.views.media
        data:
          url: https://assets.castloop.ai/xnarrator-game/editor-beta/1780365598/video/node_01.mp4
          subtitle_url: https://assets.castloop.ai/xnarrator-game/editor-beta/1780365598/subtitles/node_01.srt
          poster: https://assets.castloop.ai/xnarrator-game/editor-beta/1780365598/video/node_01_poster.jpg
          autoplay: false
    resolution:
      effects:
      - type: increment_state
        path: GAME.round
        amount: 1
  s_05_offer_a:
    type: scene
    scope:
      id: story
      visibility: public
    participants:
      static:
      - Player_1
    schedule:
      mode: none
    participant_action:
      kind: none
      response:
        mode: none
    controller_action:
      enabled: true
      controller:
        type: system
      kind: narration
    publication:
      messages:
      - audience:
          scope: story
        content:
          text: 你拉开车门坐了进去。车内，Marco 提出合约：假装恋人一起出席投资人晚宴。
      views:
      - id: s_05_offer_a_video
        kind: video
        title: 你拉开车门坐了进去。车内，Marco 提...
        audience: public
        projector: core.views.media
        data:
          url: https://assets.castloop.ai/xnarrator-game/editor-beta/1780365598/video/node_05.mp4
          subtitle_url: https://assets.castloop.ai/xnarrator-game/editor-beta/1780365598/subtitles/node_05.srt
          poster: https://assets.castloop.ai/xnarrator-game/editor-beta/1780365598/video/node_05_poster.jpg
          autoplay: false
    resolution:
      effects:
      - type: adjust_attr
        target: STORY
        attr: affection_marco
        delta: 5
      - type: increment_state
        path: GAME.round
        amount: 1
  s_04_offer_b:
    type: scene
    scope:
      id: story
      visibility: public
    participants:
      static:
      - Player_1
    schedule:
      mode: none
    participant_action:
      kind: none
      response:
        mode: none
    controller_action:
      enabled: true
      controller:
        type: system
      kind: narration
    publication:
      messages:
      - audience:
          scope: story
        content:
          text: 你没有理会他，继续往前走。但他的话追了上来——一份你无法拒绝的合约提案。
      views:
      - id: s_04_offer_b_video
        kind: video
        title: 你没有理会他，继续往前走。但他的话追了上...
